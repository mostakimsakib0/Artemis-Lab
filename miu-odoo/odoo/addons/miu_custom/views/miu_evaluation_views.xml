<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Evaluation View -->
        <record id="view_miu_evaluation_form" model="ir.ui.view">
            <field name="name">miu.evaluation.form</field>
            <field name="model">miu.evaluation</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="employee_id" required="1"/>
                            <field name="sprint_id"/>
                            <field name="project_id"/>
                            <field name="evaluation_date"/>
                            <field name="evaluated_by"/>
                        </group>
                        <group>
                            <field name="task_completion_rating"/>
                            <field name="code_discipline_rating"/>
                            <field name="communication_rating"/>
                            <field name="consistency_rating"/>
                            <field name="overall_rating" readonly="1"/>
                        </group>
                        <group colspan="4">
                            <field name="comments" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Evaluation List View -->
        <record id="view_miu_evaluation_tree" model="ir.ui.view">
            <field name="name">miu.evaluation.tree</field>
            <field name="model">miu.evaluation</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="employee_id"/>
                    <field name="sprint_id"/>
                    <field name="overall_rating"/>
                    <field name="evaluation_date"/>
                </tree>
            </field>
        </record>

        <!-- Evaluation Action -->
        <record id="action_miu_evaluation" model="ir.actions.act_window">
            <field name="name">Evaluations</field>
            <field name="res_model">miu.evaluation</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_miu_evaluation" name="Evaluations" action="action_miu_evaluation" parent="hr.menu_human_resources_employees"/>
    </data>
</odoo>
