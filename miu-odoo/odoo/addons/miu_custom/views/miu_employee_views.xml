<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Employee View -->
        <record id="view_miu_employee_form" model="ir.ui.view">
            <field name="name">miu.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" required="1"/>
                            <field name="role_tag"/>
                            <field name="batch"/>
                            <field name="github_username"/>
                        </group>
                        <group>
                            <field name="skills" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
