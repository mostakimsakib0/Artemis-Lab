<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Project View -->
        <record id="view_miu_project_form" model="ir.ui.view">
            <field name="name">miu.project.form</field>
            <field name="model">project.project</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" required="1"/>
                            <field name="batch"/>
                            <field name="github_repo"/>
                            <field name="documentation_status"/>
                        </group>
                        <group>
                            <field name="team_members" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
