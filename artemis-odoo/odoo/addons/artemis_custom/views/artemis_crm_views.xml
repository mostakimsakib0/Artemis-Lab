<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Lost Reason Wizard -->
        <record id="view_artemis_crm_lost_reason_wizard_form" model="ir.ui.view">
            <field name="name">artemis.crm.lost.reason.wizard.form</field>
            <field name="model">artemis.crm.lost.reason.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="lead_id" invisible="1"/>
                        <field name="lost_reason" placeholder="Why did we lose this deal?"/>
                    </group>
                    <footer>
                        <button name="action_confirm_lost" type="object" string="Confirm Lost" class="btn-danger"/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_artemis_crm_lost_reason_wizard" model="ir.actions.act_window">
            <field name="name">Lost Reason</field>
            <field name="res_model">artemis.crm.lost.reason.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Lead Kanban -->
        <record id="view_artemis_crm_lead_kanban" model="ir.ui.view">
            <field name="name">artemis.crm.lead.kanban</field>
            <field name="model">artemis.crm.lead</field>
            <field name="arch" type="xml">
                <kanban default_group_by="stage" class="o_kanban_mobile">
                    <field name="stage"/>
                    <field name="color"/>
                    <field name="priority"/>
                    <field name="expected_revenue"/>
                    <field name="assigned_to_id"/>
                    <field name="contact_name"/>
                    <field name="company_name"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click o_kanban_record_has_color_#{kanban_getcolor(record.color.raw_value)}">
                                <div class="o_kanban_card_header">
                                    <div class="o_kanban_card_title">
                                        <field name="contact_name"/>
                                    </div>
                                    <div class="o_kanban_card_subtitle">
                                        <field name="company_name"/>
                                    </div>
                                </div>
                                <div class="o_kanban_card_content">
                                    <div class="row">
                                        <div class="col-6">
                                            <field name="priority" widget="priority"/>
                                        </div>
                                        <div class="col-6 text-end">
                                            <field name="expected_revenue" widget="monetary"/>
                                        </div>
                                    </div>
                                    <div class="mt-2">
                                        <field name="service_ids" widget="many2many_tags"/>
                                    </div>
                                </div>
                                <div class="o_kanban_card_footer">
                                    <div class="o_kanban_footer_left">
                                        <field name="assigned_to_id" widget="avatar"/>
                                    </div>
                                    <div class="o_kanban_footer_right">
                                        <field name="probability" widget="percentpie"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Lead Form -->
        <record id="view_artemis_crm_lead_form" model="ir.ui.view">
            <field name="name">artemis.crm.lead.form</field>
            <field name="model">artemis.crm.lead</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_set_stage" type="object" args="[['contacted']]" string="Contacted" class="btn-primary" states="new"/>
                        <button name="action_set_stage" type="object" args="[['qualified']]" string="Qualify" states="contacted"/>
                        <button name="action_set_stage" type="object" args="[['proposal']]" string="Send Proposal" states="qualified"/>
                        <button name="action_mark_won" type="object" string="Won" class="btn-success" states="proposal"/>
                        <button name="action_mark_lost" type="object" string="Lost" class="btn-danger" states="new,contacted,qualified,proposal"/>
                        <field name="stage" widget="statusbar" clickable="True"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="contact_name" placeholder="Contact Name"/></h1>
                        </div>
                        <group>
                            <group string="Contact Info">
                                <field name="company_name"/>
                                <field name="email" widget="email"/>
                                <field name="phone" widget="phone"/>
                            </group>
                            <group string="Details">
                                <field name="source"/>
                                <field name="assigned_to_id"/>
                                <field name="priority" widget="priority"/>
                            </group>
                        </group>
                        <group string="Opportunity">
                            <group>
                                <field name="service_ids" widget="many2many_tags"/>
                            </group>
                            <group>
                                <field name="expected_revenue" widget="monetary"/>
                                <field name="probability" widget="percentpie"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1" placeholder="Internal notes about this lead"/>
                            <field name="lost_reason" readonly="1" attrs="{'invisible': [('stage', '!=', 'lost')]}"/>
                        </group>
                        <notebook>
                            <page string="Communication">
                                <field name="communication_log" context="{'default_lead_id': active_id}">
                                    <tree editable="bottom">
                                        <field name="date"/>
                                        <field name="type"/>
                                        <field name="subject"/>
                                        <field name="employee_id"/>
                                    </tree>
                                    <form>
                                        <group>
                                            <field name="type"/>
                                            <field name="subject"/>
                                            <field name="date"/>
                                            <field name="employee_id"/>
                                        </group>
                                        <group>
                                            <field name="body" nolabel="1"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Lead Tree -->
        <record id="view_artemis_crm_lead_tree" model="ir.ui.view">
            <field name="name">artemis.crm.lead.tree</field>
            <field name="model">artemis.crm.lead</field>
            <field name="arch" type="xml">
                <tree decoration-success="stage == 'won'" decoration-danger="stage == 'lost'" decoration-info="stage == 'proposal'">
                    <field name="contact_name"/>
                    <field name="company_name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="stage"/>
                    <field name="priority" widget="priority"/>
                    <field name="expected_revenue" widget="monetary"/>
                    <field name="probability" widget="percentpie"/>
                    <field name="assigned_to_id"/>
                </tree>
            </field>
        </record>

        <!-- Lead Search -->
        <record id="view_artemis_crm_lead_search" model="ir.ui.view">
            <field name="name">artemis.crm.lead.search</field>
            <field name="model">artemis.crm.lead</field>
            <field name="arch" type="xml">
                <search>
                    <field name="contact_name"/>
                    <field name="company_name"/>
                    <field name="email"/>
                    <filter name="my_leads" string="My Leads" domain="[('assigned_to_id.user_id', '=', uid)]"/>
                    <filter name="stage_new" string="New" domain="[('stage', '=', 'new')]"/>
                    <filter name="stage_won" string="Won" domain="[('stage', '=', 'won')]"/>
                    <separator/>
                    <filter name="group_stage" string="Stage" context="{'group_by': 'stage'}"/>
                    <filter name="group_source" string="Source" context="{'group_by': 'source'}"/>
                    <filter name="group_assigned" string="Assigned To" context="{'group_by': 'assigned_to_id'}"/>
                </search>
            </field>
        </record>

        <!-- Lead Actions -->
        <record id="action_artemis_crm_lead" model="ir.actions.act_window">
            <field name="name">Leads</field>
            <field name="res_model">artemis.crm.lead</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_artemis_crm_lead_search"/>
        </record>

        <!-- Services -->
        <record id="view_artemis_service_tree" model="ir.ui.view">
            <field name="name">artemis.service.tree</field>
            <field name="model">artemis.service</field>
            <field name="arch" type="xml">
                <tree editable="bottom">
                    <field name="sequence"/>
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="action_artemis_service" model="ir.actions.act_window">
            <field name="name">Services</field>
            <field name="res_model">artemis.service</field>
            <field name="view_mode">tree</field>
        </record>

        <!-- Menus -->
        <menuitem id="menu_artemis_crm" name="CRM" sequence="2" parent="project.menu_project_management"/>
        <menuitem id="menu_artemis_crm_leads" name="Leads" parent="menu_artemis_crm" action="action_artemis_crm_lead" sequence="10"/>
        <menuitem id="menu_artemis_crm_services" name="Services" parent="menu_artemis_crm" action="action_artemis_service" sequence="99"/>
    </data>
</odoo>
