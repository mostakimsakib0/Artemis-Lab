<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_artemis_ticket_form" model="ir.ui.view">
            <field name="name">artemis.ticket.form</field>
            <field name="model">artemis.ticket</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_assign" type="object" string="Start Progress" class="btn-primary" states="new"/>
                        <button name="action_resolve" type="object" string="Resolve" class="btn-success" states="in_progress"/>
                        <button name="action_close" type="object" string="Close" class="btn-secondary" states="resolved"/>
                        <button name="action_reopen" type="object" string="Reopen" class="btn-warning" states="closed"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="requester_id"/>
                            <field name="assigned_to_id"/>
                            <field name="category"/>
                            <field name="priority" widget="priority"/>
                            <field name="project_id"/>
                            <field name="deadline"/>
                        </group>
                        <group>
                            <field name="description" nolabel="1"/>
                        </group>
                        <group string="Resolution" attrs="{'invisible': [('state', 'not in', ('resolved', 'closed'))]}">
                            <field name="resolution" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_artemis_ticket_tree" model="ir.ui.view">
            <field name="name">artemis.ticket.tree</field>
            <field name="model">artemis.ticket</field>
            <field name="arch" type="xml">
                <tree decoration-danger="state not in ('resolved','closed') and deadline and deadline &lt; current_date" decoration-success="state == 'closed'">
                    <field name="name"/>
                    <field name="requester_id"/>
                    <field name="assigned_to_id"/>
                    <field name="category"/>
                    <field name="priority" widget="priority"/>
                    <field name="state"/>
                    <field name="deadline"/>
                </tree>
            </field>
        </record>

        <record id="view_artemis_ticket_kanban" model="ir.ui.view">
            <field name="name">artemis.ticket.kanban</field>
            <field name="model">artemis.ticket</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="name"/>
                    <field name="priority"/>
                    <field name="state"/>
                    <field name="assigned_to_id"/>
                    <field name="deadline"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <field name="priority" widget="priority"/>
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="assigned_to_id" widget="many2one_avatar_user"/>
                                    <div t-if="record.deadline.raw_value">
                                        Deadline: <field name="deadline"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_artemis_ticket_search" model="ir.ui.view">
            <field name="name">artemis.ticket.search</field>
            <field name="model">artemis.ticket</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="requester_id"/>
                    <field name="assigned_to_id"/>
                    <filter name="filter_my" string="My Tickets" domain="[('assigned_to_id', '=', uid)]"/>
                    <filter name="filter_open" string="Open" domain="[('state', 'not in', ('closed',))]"/>
                    <filter name="filter_high" string="High Priority" domain="[('priority', '>=', '2')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
                        <filter name="group_priority" string="Priority" context="{'group_by': 'priority'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_artemis_ticket" model="ir.actions.act_window">
            <field name="name">Tickets</field>
            <field name="res_model">artemis.ticket</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_artemis_ticket_search"/>
        </record>

        <menuitem id="menu_artemis_helpdesk" name="Helpdesk" sequence="5" parent="project.menu_project_management"/>
        <menuitem id="menu_artemis_tickets" name="Tickets" parent="menu_artemis_helpdesk" action="action_artemis_ticket" sequence="10"/>
    </data>
</odoo>
