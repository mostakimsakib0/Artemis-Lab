<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_artemis_project_form_inherit" model="ir.ui.view">
            <field name="name">artemis.project.form.inherit</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="after">
                    <field name="batch"/>
                    <field name="github_repo"/>
                    <field name="documentation_status"/>
                    <field name="team_members" widget="many2many_tags"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
