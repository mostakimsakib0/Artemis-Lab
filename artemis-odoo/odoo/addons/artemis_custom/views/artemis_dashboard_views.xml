<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_artemis_dashboard_form" model="ir.ui.view">
            <field name="name">artemis.dashboard.form</field>
            <field name="model">artemis.dashboard</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_refresh" type="object" string="Refresh" class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>CEO Dashboard</h1>
                        </div>

                        <group string="Projects">
                            <field name="total_projects" widget="stat" class="text-bg-primary"/>
                            <field name="active_projects" widget="stat" class="text-bg-success"/>
                        </group>

                        <group string="Tasks">
                            <group>
                                <field name="total_tasks" widget="stat"/>
                                <field name="tasks_todo" widget="stat"/>
                                <field name="tasks_in_progress" widget="stat"/>
                                <field name="tasks_in_review" widget="stat"/>
                            </group>
                            <group>
                                <field name="tasks_approved" widget="stat"/>
                                <field name="tasks_rejected" widget="stat"/>
                                <field name="overdue_tasks" widget="stat" class="text-bg-danger"/>
                                <field name="on_time_rate" widget="progressbar"/>
                            </group>
                        </group>

                        <group string="Average Ratings (Last Sprint)">
                            <group>
                                <field name="avg_task_rating"/>
                                <field name="avg_code_rating"/>
                            </group>
                            <group>
                                <field name="avg_comm_rating"/>
                                <field name="avg_consistency_rating"/>
                            </group>
                            <group>
                                <field name="avg_overall"/>
                            </group>
                        </group>

                        <group string="Team">
                            <field name="total_employees" widget="stat"/>
                            <field name="total_evaluations" widget="stat"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_artemis_dashboard" model="ir.actions.act_window">
            <field name="name">CEO Dashboard</field>
            <field name="res_model">artemis.dashboard</field>
            <field name="view_mode">form</field>
        </record>

        <menuitem id="menu_artemis_dashboard" name="CEO Dashboard" action="action_artemis_dashboard" sequence="0" parent="project.menu_project_management"/>

        <!-- Employee Dashboard -->
        <record id="view_artemis_employee_dashboard_form" model="ir.ui.view">
            <field name="name">artemis.employee.dashboard.form</field>
            <field name="model">artemis.employee.dashboard</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_refresh" type="object" string="Refresh" class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>My Dashboard</h1>
                            <h2><field name="employee_id" readonly="1"/></h2>
                        </div>

                        <group string="My Tasks">
                            <group>
                                <field name="my_total_tasks" widget="stat"/>
                                <field name="my_todo" widget="stat"/>
                                <field name="my_in_progress" widget="stat"/>
                                <field name="my_in_review" widget="stat"/>
                            </group>
                            <group>
                                <field name="my_approved" widget="stat" class="text-bg-success"/>
                                <field name="my_rejected" widget="stat" class="text-bg-danger"/>
                                <field name="my_overdue" widget="stat" class="text-bg-danger"/>
                            </group>
                        </group>

                        <group string="My Evaluations">
                            <field name="my_total_evaluations" widget="stat"/>
                            <field name="my_avg_overall"/>
                        </group>

                        <group string="My Leaves">
                            <group>
                                <field name="my_pending_leaves" widget="stat"/>
                                <field name="my_approved_leaves" widget="stat"/>
                            </group>
                            <group>
                                <field name="my_total_leave_days" widget="stat"/>
                            </group>
                        </group>

                        <group string="My Expenses">
                            <field name="my_total_expenses" widget="monetary"/>
                            <field name="my_pending_expenses" widget="monetary"/>
                        </group>

                        <group string="My Tickets">
                            <field name="my_open_tickets" widget="stat"/>
                            <field name="my_resolved_tickets" widget="stat"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_artemis_employee_dashboard" model="ir.actions.act_window">
            <field name="name">My Dashboard</field>
            <field name="res_model">artemis.employee.dashboard</field>
            <field name="view_mode">form</field>
        </record>

        <menuitem id="menu_artemis_employee_dashboard" name="My Dashboard" action="action_artemis_employee_dashboard" sequence="1" parent="project.menu_project_management"/>
    </data>
</odoo>
