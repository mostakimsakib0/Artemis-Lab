# Artemis Lab — Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_DB=artemis_lab
POSTGRES_USER=artemis
POSTGRES_PASSWORD=change_this_to_a_secure_password

# Odoo
ODOO_ADMIN_PASSWD=change_this_to_a_secure_password
ODOO_DB_HOST=db
ODOO_DB_PORT=5432
ODOO_DB_USER=artemis
ODOO_DB_PASSWORD=change_this_to_a_secure_password
ODOO_DB_NAME=artemis_lab
ODOO_PORT=8069

# Email
HOST_EMAIL=noreply@artemis-lab.local
